# Shared Supabase env for apps/web and apps/cli
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# CLI also accepts SUPABASE_URL / SUPABASE_ANON_KEY.
# Keep these in sync with NEXT_PUBLIC_* unless you intentionally split them.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: local redirect URL used by signup page in development
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/callback

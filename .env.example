# Shared Supabase env for apps/web and apps/cli
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional legacy aliases. Web auto-maps SUPABASE_* to NEXT_PUBLIC_* if omitted.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: local redirect URL used by signup page in development
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/callback
